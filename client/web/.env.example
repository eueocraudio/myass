# Locutus (web pública PHP) — copie para .env e preencha. NÃO comitar o .env.

# Banco público (MySQL) usado pelas APIs deste projeto PHP.
DB_HOST=localhost
DB_NAME=myass_locutus
DB_USER=trocar
DB_PASS=trocar

# TTL dos blobs (segundos) — dead drop efêmero.
BLOB_TTL=86400

# Deploy do ambiente web por FTP (usado pelo script de publicação, não pela app).
FTP_HOST=ftp.exemplo.com
FTP_USER=trocar
FTP_PASS=trocar
FTP_DIR=/public_html
