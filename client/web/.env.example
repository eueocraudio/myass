# Locutus (web pública PHP) — copie para .env e preencha. NÃO comitar o .env.
# (o .gitignore já ignora .env; o deploy.py sobe um .env SANITIZADO ao servidor,
#  contendo só as variáveis DB_*/BLOB_TTL — as credenciais de FTP ficam locais.)

# --- Vão para o servidor (o index.php lê em runtime) -------------------
# Banco público (MySQL/MariaDB) usado pelas APIs deste projeto PHP.
DB_HOST=localhost
DB_NAME=myass_locutus
DB_USER=trocar
DB_PASS=trocar

# TTL dos blobs (segundos) — dead drop efêmero.
BLOB_TTL=86400

# --- Só locais (deploy por FTP; NUNCA sobem ao servidor) --------------
FTP_HOST=ftp.wellington.tec.br
FTP_USER=trocar
FTP_PASS=trocar
FTP_DIR=/public_html
FTP_TLS=1            # 1 = FTPS (FTP sobre TLS explícito, recomendado); 0 = FTP puro
