# Roteia tudo o que não for arquivo/dir existente para o index.php (os endereços
# de blob 64-hex são dinâmicos). Arquivos estáticos (index.html, js/) são servidos
# direto pelo servidor.
RewriteEngine On

# SEGURANÇA: bloqueia acesso direto a qualquer dotfile (.env com as credenciais do
# MySQL, .htaccess etc.) — qualquer componente de caminho começando com ponto → 403.
# Feito via mod_rewrite (já habilitado) para não depender da versão do Apache
# (Require all denied vs Order/Deny).
RewriteRule (^|/)\.(?!well-known/) - [F]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

# CACHE: a app é estática mas muda a cada deploy; sem isto o browser serve um
# app.js/HTML velho do cache contra um HTML/JS novo (botões somem, erros tipo
# "$(...) is null"). Força revalidação a cada carga (no-cache não é "no-store":
# o browser ainda usa o cache, mas SEMPRE revalida com o servidor via ETag).
<IfModule mod_headers.c>
  <FilesMatch "\.(html|js|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
